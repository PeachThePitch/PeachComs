{% extends 'base.html.twig' %}
{% block title %}
	{{ parent() }}
	- Mes Commandes
{% endblock %}
{% block stylesheets %}
	<link href="css/stylesheet.css" rel="stylesheet">
	<link href="css/bootstrap.min.css" rel="stylesheet">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
	<h1 class="ms-5 mocha text-success mt-4 pt-4 mb-4 text-center  display-1 ">
		Mes Commandes
	</h1>

	{% if commandes is empty %}
		<p class="text-center garet fs-4 mt-5">Tu n'as pas encore de commandes 🛍️</p>
	{% else %}
		<div class="container mt-3 mb-5">
			{% for commande in commandes %}

				{% if commande.etat == 'En attente' %}
					{% set badgeClass = 'bg-warning text-dark' %}
					{% set icone = 'bi bi-hourglass-split' %}
				{% elseif commande.etat == 'En cours' %}
					{% set badgeClass = 'bg-info text-light' %}
					{% set icone = 'bi bi-palette-fill' %}
				{% else %}
					{% set badgeClass = 'bg-success text-light' %}
					{% set icone = 'bi bi-check-circle-fill' %}
				{% endif %}


				<div class="border border-3 border-dark rounded-4 p-4 mb-3 bg-white">
					<div
						class="d-flex justify-content-between align-items-center flex-wrap gap-3">

						{# Infos principales #}
						<div>
							<p class="mocha fs-4 text-info mb-1">
								Commande du
								{{ commande.dateCommande | date('d/m/Y à H:i') }}
							</p>
							<span class="badge {{ badgeClass }} garet fs-6">
								<i class="{{ icone }}"></i>
								{{ commande.etat }}
							</span>
						</div>

						{# Prix #}
						<div class="text-end">
							<p class="garet fw-bold fs-4 text-info mb-0">
								{{ commande.total | number_format(2, '.', '') }}€ TTC
							</p>
						</div>

						
						{# Bouton Chat #}
						<div class="position-relative d-inline-block">
							{% set nonLus = 0 %}
							{% for message in commande.messages %}
								{% if not message.lu and message.user != app.user %}
									{% set nonLus = nonLus + 1 %}
								{% endif %}
							{% endfor %}
							<a href="{{ path('app_chat', {'id': commande.id}) }}" class="btn btn-info">
								<p class="garet fw-bold mb-0">
									<i class="bi bi-chat-heart-fill"></i>
									Contacter l'artiste
								</p>
							</a>
							{% if nonLus > 0 %}
								<span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-2 border-white">
									{{ nonLus }}
								</span>
							{% endif %}
						</div>

						{# Barre de progression #}
						<div class="mt-3 justify-content-center col-6">
							<div class="d-flex justify-content-between garet fw-bold mb-1" style="font-size: 0.85rem;">
								<span class="{{ commande.etat == 'En attente' or commande.etat == 'En cours' or commande.etat == 'Terminée' ? 'text-info' : 'text-muted' }}">
									<i class="bi bi-hourglass-split"></i>
									En attente
								</span>
								<span class="{{ commande.etat == 'En cours' or commande.etat == 'Terminée' ? 'text-info' : 'text-muted' }}">
									<i class="bi bi-palette-fill"></i>
									En cours
								</span>
								<span class="{{ commande.etat == 'Terminée' ? 'text-info' : 'text-muted' }}">
									<i class="bi bi-check-circle-fill"></i>
									Terminée
								</span>
							</div>
							<div class="progress border border-2 border-dark rounded-pill" style="height: 18px;">
								<div class="progress-bar bg-info" style="width: {{
																		                commande.etat == 'En attente' ? '15' :
																		                commande.etat == 'En cours' ? '55' :
																		                '100'
																		             }}%; transition: width 0.5s ease;"></div>
							</div>
						</div>

					</div>
				</div>

			{% endfor %}
		</div>
	{% endif %}
{% endblock %}
