{% extends 'base.html.twig' %}
{% block title %}
	{{ parent() }}
	-
	{{ produit.designation }}
{% endblock %}
{% block stylesheets %}
	<link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
	<link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
	<div class="container-fluid px-4 mt-4 mb-5">
		<div
			class="row gap-4 justify-content-center">

			{# ── 3/4 Détails produit ── #}
			<div
				class="col-8">

				{# Image de couverture #}
				<img
				src="{{ asset('images/' ~ produit.image) }}" alt="{{ produit.designation }}" class="w-100 rounded-4 border border-3 border-dark mb-4" style="max-height: fit-content; object-fit: cover;">

				{# Intitulé #}
				<h1 class="mocha text-info display-1 mb-3">{{ produit.designation }}</h1>

				{# Description #}
				{% if produit.description %}
					<div class="border border-3 border-dark rounded-4 p-4 bg-white mb-4">
						<p class="garet fs-5 mb-0" style="white-space: pre-line;">{{ produit.description }}</p>
					</div>
				{% endif %}

				{# Photos d'exemples #}
				{% if produit.photos and produit.photos | length > 0 %}
					<h2 class="mocha text-info fs-2 mb-3">Exemples</h2>
					<div class="row justify-content-start gap-3 ms-1">
						{% for photo in produit.photos %}
							<div class="col-auto">
								<img src="{{ asset('images/exemples/' ~ photo) }}" class="rounded-4 border border-3 border-dark" style="height: 220px; object-fit: cover;">
							</div>
						{% endfor %}
					</div>
				{% endif %}

			</div>

			{# ── 1/4 Panel ── #}
			<div class="col-3">
				<div class="border border-3 border-dark rounded-4 p-4 bg-white sticky-top" style="top: 100px;">

					<p class="mocha fs-2 text-info text-center mb-1">{{ produit.designation }}</p>
					<p class="garet fw-bold fs-4 text-center text-info mb-4">
						{{ produit.prix | number_format(2, '.', '') }}€
					</p>

					{# Quantité #}
					<div class="d-flex align-items-center justify-content-center gap-3 mb-4">
						<button class="btn btn-outline-dark" id="btn-moins">
							<i class="bi bi-dash"></i>
						</button>
						<span class="garet fw-bold fs-4" id="quantite">1</span>
						<button class="btn btn-outline-dark" id="btn-plus">
							<i class="bi bi-plus"></i>
						</button>
					</div>

					{% if produit.slots is not null %}
						<div class="text-center mb-3">
							{% if produit.slots > 0 %}
								<span class="badge bg-success garet fs-6">
									<i class="bi bi-check-circle-fill"></i>
									{{ produit.slots }}
									slot(s) disponible(s)
								</span>
							{% else %}
								<span class="badge bg-danger garet fs-6">
									<i class="bi bi-x-circle-fill"></i>
									Complet
								</span>
							{% endif %}
						</div>

						{% if produit.slots == 0 %}
							<button class="btn btn-secondary w-100 mb-2" disabled>
								<span class="garet fw-bold text-light">
									<i class="bi bi-basket2-fill"></i>
									Indisponible
								</span>
							</button>
						{% else %}
							<form method="post" action="{{ path('app_panier_ajouter', {'id': produit.id}) }}" id="form-panier">
								<input type="hidden" name="quantite" id="input-quantite" value="1">
								<button type="submit" class="btn btn-info w-100 mb-2">
									<span class="garet fw-bold text-light">
										<i class="bi bi-basket2-fill"></i>
										Ajouter au panier
									</span>
								</button>
							</form>
						{% endif %}
					{% else %}
						<form method="post" action="{{ path('app_panier_ajouter', {'id': produit.id}) }}" id="form-panier">
							<input type="hidden" name="quantite" id="input-quantite" value="1">
							<button type="submit" class="btn btn-info w-100 mb-2">
								<span class="garet fw-bold text-light">
									<i class="bi bi-basket2-fill"></i>
									Ajouter au panier
								</span>
							</button>
						</form>
					{% endif %}


					{# Favori #}
					{% if is_granted('IS_AUTHENTICATED_FULLY') %}
						<a href="{{ path('app_favoris', {'id': produit.id}) }}" class="btn btn-outline-dark w-100 mb-3">
							<span class="garet fw-bold">
								{% if produit in app.user.produits %}
									<i class="bi bi-heart-fill text-danger"></i>
									Retirer des favoris
								{% else %}
									<i class="bi bi-heart"></i>
									Ajouter aux favoris
								{% endif %}
							</span>
						</a>
					{% else %}
						<a href="{{ path('app_login') }}" class="btn btn-outline-dark w-100 mb-3">
							<span class="garet fw-bold">
								<i class="bi bi-heart"></i>
								Ajouter aux favoris
							</span>
						</a>
					{% endif %}

					{# Bouton admin #}
					{% if is_granted('ROLE_ADMIN') %}
						<hr class="border border-2 border-dark">
						<a href="{{ path('app_admin_produit_modifier', {'id': produit.id}) }}" class="btn btn-warning w-100">
							<span class="garet fw-bold">
								<i class="bi bi-pencil-fill"></i>
								Modifier ce produit
							</span>
						</a>
					{% endif %}

				</div>
			</div>

		</div>
	</div>

	<script>
		const btnMoins = document.getElementById('btn-moins');
const btnPlus = document.getElementById('btn-plus');
const quantiteDisplay = document.getElementById('quantite');
const inputQuantite = document.getElementById('input-quantite');
let quantite = 1;

btnPlus.addEventListener('click', () => {
quantite++;
quantiteDisplay.textContent = quantite;
inputQuantite.value = quantite;
});

btnMoins.addEventListener('click', () => {
if (quantite > 1) {
quantite--;
quantiteDisplay.textContent = quantite;
inputQuantite.value = quantite;
}
});
	</script>
{% endblock %}
