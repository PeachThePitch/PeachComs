{% extends 'base.html.twig' %}
{% block title %}
	{{ parent() }}
	- Accueil
{% endblock %}
{% block stylesheets %}
	<link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
	<link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}

	{# ── Hero ── #}
	<div class="container mt-5 mb-5">
		<div
			class="row align-items-center gap-4 justify-content-center">

			{# Image hero #}
			<div class="col-5 herotext ">
				<img id="hero" src="{{ asset('images/accueil.jpeg') }}" alt="Illustration de présentation" class="hero-image border rounded-circle border-4">
			</div>

			{# Texte de bienvenue #}
			<div class="col-5 herotext">
				<p class="mocha text-info mb-1" style="font-size: 1.2rem;">Bienvenue sur</p>
				<h1 class="mocha text-success display-1 mb-3">PeachComs</h1>
				<p class="garet fs-5 mb-4">
					Salut ! Moi c'est
					<strong>Peach</strong>, artiste furry passionnée depuis plus de
					<strong>7 ans</strong>. Ici tu trouveras mes commissions artistiques, réalisées
						                    avec amour dans un style
					<strong>cartoon coloré</strong>
					qui me ressemble !
				</p>

				{# Réseaux sociaux #}
				<div class="bouton-acc">
					<div class="d-flex gap-3 align-items-center mb-4">
						<a href="https://www.tiktok.com/@peachthefurry" target="_blank" class="social-btn btn btn-dark text-light ">
							<i class="bi bi-tiktok text-white"></i>
						</a>
						<a href="https://discord.gg/toninvitation" target="_blank" class="social-btn btn btn-purple text-light ">
							<i class="bi bi-discord text-white"></i>
						</a>
					</div>

					<a id="comm-acc" href="{{ path('app_commissions') }}" class="btn btn-info btn-lg ">
						<span class="garet fw-bold text-light">
							<i class="bi bi-palette-fill"></i>
							Voir mes commissions
						</span>
					</a>
				</div>
			</div>

		</div>
	</div>

	{# ── Sections présentation ── #}
	<div class="container mb-5">
		<div
			class="row justify-content-center gap-4">

			{# Qui je suis #}
			<div class="col-10 section-card mb-2">
				<h2 class="mocha text-info fs-1 mb-3">
					<i class="bi bi-person-heart-fill"></i>
					Qui je suis
				</h2>
				<p class="garet fs-5">
					Je m'appelle
					<strong>Peach</strong>, artiste autodidacte passionnée par l'art depuis
						                    toute petite. J'ai rejoint la communauté furry il y a
					<strong>7 ans</strong>
					et
					                    c'est là que ma passion pour le dessin a vraiment décollé. Ce qui a commencé
					                    comme un simple hobby est devenu une véritable vocation — aujourd'hui je crée
					                    des personnages expressifs et colorés qui racontent des histoires rien qu'en
					                    une image !
				</p>
			</div>

			{# Style artistique #}
			<div class="col-10 section-card mb-2 ps-4">
				<h2 class="mocha text-info fs-1 mb-3">
					<i class="bi bi-brush-fill"></i>
					Mon style artistique
				</h2>
				<p class="garet fs-5">
					Mon style est résolument
					<strong>cartoon</strong>
					— des lignes expressives,
					                    des couleurs vives et des personnages pleins de vie ! J'aime jouer avec
					                    les expressions et les poses dynamiques pour donner un maximum de personnalité
					                    à chaque illustration. Que ce soit en
					<strong>sketch rapide</strong>
					ou en
					<strong>full shaded soigné</strong>, j'apporte toujours le même soin du détail
						                    à chaque commission.
				</p>
			</div>

			{# Spécialités #}
			<div class="col-10 section-card mb-2 ps-4">
				<h2 class="mocha text-info fs-1 mb-3">
					<i class="bi bi-stars"></i>
					Ce que je dessine
				</h2>
				<div class="row gap-3 justify-content-start ms-1">
					{% set specialites = [
                        {'icone': 'bi-person-bounding-box', 'titre': 'Fursonas', 'desc': 'Portraits et full body de tes personnages furry'},
                        {'icone': 'bi-image-fill', 'titre': 'Reference Sheets', 'desc': 'Fiches de référence complètes pour tes OC'},
                        {'icone': 'bi-people-fill', 'titre': 'YCH', 'desc': 'Your Character Here — poses prédéfinies à personnaliser'},
                        {'icone': 'bi-heart-fill', 'titre': 'Adopts', 'desc': 'Personnages originaux à adopter'},
                    ] %}
					{% for s in specialites %}
						<div class="col-auto border border-2 border-dark rounded-4 p-3 text-center" style="width: 200px;">
							<i class="bi {{ s.icone }} text-success fs-2 mb-2 d-block"></i>
							<p class="mocha text-success fs-5 mb-1">{{ s.titre }}</p>
							<p class="garet" style="font-size: 0.85rem;">{{ s.desc }}</p>
						</div>
					{% endfor %}
				</div>
			</div>

			{# TOS #}
			<div class="col-10 section-card mb-2 ps-4">
				<h2 class="mocha text-info fs-1 mb-3">
					<i class="bi bi-file-earmark-text-fill"></i>
					Conditions d'utilisation (TOS)
				</h2>
				<div class="tos-item">
					<p class="garet fw-bold mb-0">
						Ce que tu peux faire</p>
					<p class="garet">Utiliser l'illustration à des fins personnelles, la poster sur tes réseaux en me créditant, l'utiliser comme avatar ou bannière.</p>
				</div>
				<div class="tos-item">
					<p class="garet fw-bold mb-0">
						Ce que tu ne peux pas faire</p>
					<p class="garet">Revendre l'illustration, retirer ma signature, l'utiliser à des fins commerciales sans accord préalable, ou la revendiquer comme tienne.</p>
				</div>
				<div class="tos-item">
					<p class="garet fw-bold mb-0">
						Paiement</p>
					<p class="garet">Le paiement s'effectue en totalité avant le début du travail. Je me réserve le droit de refuser une commission sans justification.</p>
				</div>
				<div class="tos-item">
					<p class="garet fw-bold mb-0">
						Révisions</p>
					<p class="garet mb-0">Deux révisions mineures incluses par commission. Toute révision supplémentaire sera facturée.</p>
				</div>
			</div>

		</div>
	</div>

{% endblock %}
