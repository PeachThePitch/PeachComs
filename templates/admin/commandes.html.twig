{% extends 'base.html.twig' %}
{% block title %}
	{{ parent() }}
	- Admin Commandes
{% endblock %}
{% block stylesheets %}
	<link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
	<link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
	<div class="container mt-4 mb-5">

		<div class="d-flex align-items-center mb-4 gap-3">
			<a href="{{ path('app_admin') }}" class="btn btn-outline-dark">
				<i class="bi bi-arrow-left"></i>
			</a>
			<h1 class="mocha text-info display-1 mb-0">Commandes</h1>
		</div>

		{% if commandes is empty %}
			<p class="text-center garet fs-4 mt-5">Aucune commande pour l'instant 🛍️</p>
		{% else %}
			{% for commande in commandes %}

				{% if commande.etat == 'En attente' %}
					{% set badgeClass = 'bg-warning text-dark' %}
					{% set icone = 'bi bi-hourglass-split' %}
				{% elseif commande.etat == 'En cours' %}
					{% set badgeClass = 'bg-info text-light' %}
					{% set icone = 'bi bi-palette-fill' %}
				{% else %}
					{% set badgeClass = 'bg-success text-light' %}
					{% set icone = 'bi bi-check-circle-fill' %}
				{% endif %}

				<div class="border border-3 border-dark rounded-4 p-4 mb-3 bg-white">
					<div
						class="d-flex justify-content-between align-items-center flex-wrap gap-3">

						{# Infos #}
						<div>
							<p class="mocha fs-4 text-info mb-1">
								{{ commande.user.email }}
							</p>
							<p class="garet text-muted mb-1">
								Commande du
								{{ commande.dateCommande | date('d/m/Y à H:i') }}
							</p>
							<span class="badge {{ badgeClass }} garet fs-6">
								<i class="{{ icone }}"></i>
								{{ commande.etat }}
							</span>
						</div>

						{# Prix #}
						<div class="text-end">
							<p class="garet fw-bold fs-4 text-info mb-0">
								{{ commande.total | number_format(2, '.', '') }}€ TTC
							</p>
						</div>

						{# Changer l'état #}
						<form method="post" action="{{ path('app_admin_commande_etat', {'id': commande.id}) }}">
							<div class="d-flex gap-2 align-items-center">
								<select name="etat" class="form-select garet border border-2 border-dark rounded-3">
									<option value="En attente" {{ commande.etat == 'En attente' ? 'selected' }}>⏳ En attente</option>
									<option value="En cours" {{ commande.etat == 'En cours' ? 'selected' }}>🎨 En cours</option>
									<option value="Terminée" {{ commande.etat == 'Terminée' ? 'selected' }}>✅ Terminée</option>
								</select>
								<button type="submit" class="btn btn-info">
									<i class="bi bi-check-lg text-light"></i>
								</button>
							</div>
						</form>

						{# Chat #}
						<a href="{{ path('app_admin_chat', {'id': commande.id}) }}" class="btn btn-info">
							<i class="bi bi-chat-heart-fill"></i>
							Chat
						</a>

						{# Supprimer #}
						<form method="post" action="{{ path('app_admin_commande_supprimer', {'id': commande.id}) }}" onsubmit="return confirm('Supprimer cette commande et sa messagerie ?')">
							<button type="submit" class="btn btn-danger">
								<i class="bi bi-trash3-fill"></i>
							</button>
						</form>

					</div>
				</div>

			{% endfor %}
		{% endif %}

	</div>
{% endblock %}
