{% extends 'base.html.twig' %}
{% block title %}{{ parent() }} - Admin Avis{% endblock %}
{% block stylesheets %}
    <link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
    <div class="container mt-4 mb-5">

        <div class="d-flex align-items-center mb-4 gap-3">
            <a href="{{ path('app_admin') }}" class="btn btn-outline-dark">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="mocha text-info display-1 mb-0">Avis</h1>
        </div>

        {% if avis is empty %}
            <p class="text-center garet fs-4 mt-5">Aucun avis pour l'instant 🌟</p>
        {% else %}
            {% for a in avis %}
                <div class="border border-3 {{ a.valide ? 'border-success' : 'border-warning' }} rounded-4 p-4 mb-3 bg-white">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                        <div class="flex-grow-1">
                            {# Statut #}
                            <span class="badge {{ a.valide ? 'bg-success' : 'bg-warning text-dark' }} garet mb-2">
                                {{ a.valide ? '✅ Publié' : '⏳ En attente de validation' }}
                            </span>

                            {# Étoiles #}
                            <div class="d-flex gap-1 mb-2">
                                {% for i in 1..5 %}
                                    <i class="bi {{ a.note >= i ? 'bi-star-fill' : 'bi-star' }} text-warning"></i>
                                {% endfor %}
                            </div>

                            {# Auteur + date #}
                            <p class="mocha text-info fs-5 mb-1">{{ a.user.email }}</p>
                            <p class="garet text-muted mb-2" style="font-size: 0.85rem;">
                                Commande du {{ a.commande.dateCommande | date('d/m/Y') }}
                                — Avis du {{ a.dateAvis | date('d/m/Y') }}
                            </p>

                            {# Commentaire #}
                            {% if a.commentaire %}
                                <p class="garet mb-2">{{ a.commentaire }}</p>
                            {% endif %}

                            {# Image #}
                            {% if a.image %}
                                <img src="{{ asset('images/avis/' ~ a.image) }}"
                                     class="rounded-3 border border-2 border-dark"
                                     style="height: 120px; object-fit: cover;">
                            {% endif %}
                        </div>

                        {# Actions #}
                        <div class="d-flex flex-column gap-2">
                            <form method="post" action="{{ path('app_admin_avis_valider', {'id': a.id}) }}">
                                <button type="submit" class="btn {{ a.valide ? 'btn-warning' : 'btn-success' }} w-100">
                                    <span class="garet fw-bold">
                                        {{ a.valide ? '⏸ Dépublier' : '✅ Valider' }}
                                    </span>
                                </button>
                            </form>
                            <form method="post"
                                  action="{{ path('app_admin_avis_supprimer', {'id': a.id}) }}"
                                  onsubmit="return confirm('Supprimer cet avis ?')">
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            {% endfor %}
        {% endif %}

    </div>
{% endblock %}