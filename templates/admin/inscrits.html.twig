{% extends 'base.html.twig' %}
{% block title %}{{ parent() }} - Admin Inscrits{% endblock %}
{% block stylesheets %}
    <link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
    <div class="container mt-4 mb-5">

        <div class="d-flex align-items-center mb-4 gap-3">
            <a href="{{ path('app_admin') }}" class="btn btn-outline-dark">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="mocha text-info display-1 mb-0">Inscrits</h1>
        </div>

        <div class="border border-3 border-dark rounded-4 bg-white overflow-hidden">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="garet">Email</th>
                        <th class="garet">Rôle</th>
                        <th class="garet">Commandes</th>
                        <th class="garet">Favoris</th>
                        <th class="garet">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td class="garet fw-bold align-middle">{{ user.email }}</td>

                            {# Changer le rôle #}
                            <td class="align-middle">
                                {% if user == app.user %}
                                    <span class="badge bg-danger garet">Admin (vous)</span>
                                {% else %}
                                    <form method="post" action="{{ path('app_admin_inscrit_role', {'id': user.id}) }}" class="d-flex gap-2 align-items-center">
                                        <select name="role" class="form-select form-select-sm border border-2 border-dark rounded-3 garet" style="width: auto;">
                                            <option value="ROLE_USER" {{ 'ROLE_ADMIN' not in user.roles ? 'selected' : '' }}>Client</option>
                                            <option value="ROLE_ADMIN" {{ 'ROLE_ADMIN' in user.roles ? 'selected' : '' }}>Admin</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-info">
                                            <i class="bi bi-check-lg text-light"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </td>

                            <td class="garet align-middle">{{ user.commandes | length }}</td>
                            <td class="garet align-middle">{{ user.produits | length }}</td>

                            {# Supprimer #}
                            <td class="align-middle">
                                {% if user != app.user %}
                                    <form method="post"
                                          action="{{ path('app_admin_inscrit_supprimer', {'id': user.id}) }}"
                                          onsubmit="return confirm('Supprimer le compte de {{ user.email }} ?')">
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                {% else %}
                                    <span class="text-muted garet" style="font-size: 0.8rem;">—</span>
                                {% endif %}
                            </td>

                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>
{% endblock %}