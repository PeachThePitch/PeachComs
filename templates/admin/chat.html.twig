{% extends 'base.html.twig' %}
{% block title %}{{ parent() }} - Chat{% endblock %}
{% block stylesheets %}
    <link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
    <div class="container mt-4 mb-5" style="max-width: 800px;">

        <div class="d-flex align-items-center mb-2 gap-3">
            <a href="{{ path('app_admin_chats') }}" class="btn btn-outline-dark">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="mocha text-info display-1 mb-0">Chat</h1>
        </div>

        <p class="garet text-center text-muted mb-4">
            Commande de {{ commande.user.email }}
            du {{ commande.dateCommande | date('d/m/Y') }}
        </p>

        <div id="zone-messages">
            {% for message in messages %}
                {% set estMoi = message.user == app.user %}
                <div class="bulle {{ estMoi ? 'bulle-moi' : 'bulle-client' }}">
                    {% if message.contenu %}
                        <p class="garet mb-1">{{ message.contenu }}</p>
                    {% endif %}
                    {% if message.image %}
                        <img src="{{ asset('images/chat/' ~ message.image) }}"
                             class="img-fluid rounded-3 border border-2 border-dark mb-1"
                             style="max-width: 200px;">
                    {% endif %}
                    <small>{{ message.dateEnvoi | date('d/m/Y à H:i') }} — {{ message.user.email }}</small>
                </div>
            {% else %}
                <p class="text-center text-muted garet mt-3">Aucun message pour l'instant 💬</p>
            {% endfor %}
        </div>

        <form method="post" enctype="multipart/form-data"
              action="{{ path('app_admin_chat', {'id': commande.id}) }}">
            <div class="border border-3 border-dark rounded-4 p-3 mt-3 bg-white">
                <div class="d-flex gap-2 align-items-end">
                    <div class="flex-grow-1">
                        <input type="text" name="contenu" class="form-control garet mb-2"
                               placeholder="Ton message...">
                        <input type="file" name="image" class="form-control garet" accept="image/*">
                    </div>
                    <button type="submit" class="btn btn-info" style="height: fit-content;">
                        <i class="bi bi-send-fill text-light"></i>
                    </button>
                </div>
            </div>
        </form>

    </div>

    <script>
        const zone = document.getElementById('zone-messages');
        zone.scrollTop = zone.scrollHeight;
    </script>
{% endblock %}