{% extends 'base.html.twig' %}
{% block title %}{{ parent() }} - Connexion{% endblock %}
{% block stylesheets %}
    <link href="{{ asset('css/login-bg.css') }}" rel="stylesheet">
    <link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}

    <div class="container mt-5 pt-3 mb-5">
        <div class="row justify-content-center gap-4 align-items-start">

            {# ── Bloc connexion ── #}
            <div class="col-auto">
                <div class="border border-3 border-dark rounded-4 p-5 bg-white" style="min-width: 380px;">
                    <h1 class="mocha text-success display-4 mb-4 text-center">Connexion</h1>

                    {% if error %}
                        <div class="alert alert-danger garet">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-info garet">
                            Connecté en tant que {{ app.user.userIdentifier }},
                            <a href="{{ path('app_logout') }}">se déconnecter</a>
                        </div>
                    {% endif %}

                    <form method="post">
                        <div class="mb-3">
                            <label for="inputEmail" class="garet fw-bold mb-1">Email</label>
                            <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                                   class="form-control border border-2 border-dark rounded-3 garet"
                                   autocomplete="email" required autofocus>
                        </div>
                        <div class="mb-4">
                            <label for="inputPassword" class="garet fw-bold mb-1">Mot de passe</label>
                            <input type="password" name="password" id="inputPassword"
                                   class="form-control border border-2 border-dark rounded-3 garet"
                                   autocomplete="current-password" required>
                        </div>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        <button class="btn btn-info w-100" type="submit">
                            <span class="garet fw-bold text-light fs-5">
                                <i class="bi bi-box-arrow-in-right"></i> Se connecter
                            </span>
                        </button>
                    </form>
                </div>
            </div>

            {# ── Blocs droite ── #}
            <div class="col-auto d-flex flex-column gap-4" style="min-width: 320px; max-width: 380px;">

                {# Pourquoi se connecter #}
                <div class="border border-3 border-dark rounded-4 p-4 bg-white">
                    <h2 class="mocha text-info fs-2 mb-3">
                        <i class="bi bi-question-circle-fill"></i> Pourquoi se connecter ?
                    </h2>
                    <ul class="list-unstyled garet mb-0">
                        <li class="mb-2">
                            <i class="bi bi-heart-fill text-danger me-2"></i>
                            Accéder à tes <strong>favoris</strong>
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-basket2-fill text-dark me-2"></i>
                            Retrouver ton <strong>panier</strong>
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-bag-fill text-success me-2"></i>
                            Suivre tes <strong>commandes</strong>
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-chat-heart-fill text-info me-2"></i>
                            Échanger avec l'<strong>artiste</strong>
                        </li>
                    </ul>
                </div>

                {# Pas encore de compte #}
                <div class="border border-3 border-dark rounded-4 p-4 bg-white text-center">
                    <h2 class="mocha text-dark fs-2 mb-2">Nouveau ici ?</h2>
                    <p class="garet mb-3">Tu n'as pas encore de compte ? Rejoins la communauté !</p>
                    <a href="{{ path('app_register') }}" class="btn btn-warning w-100">
                        <span class="garet fw-bold text-light">
                            <i class="bi bi-person-plus-fill"></i> S'inscrire
                        </span>
                    </a>
                </div>

            </div>

        </div>
    </div>

{% endblock %}