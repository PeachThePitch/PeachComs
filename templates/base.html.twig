<!doctype html>
<html lang="fr">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}PeachComs{% endblock %}
		</title>
		{% block stylesheets %}
			<link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
			<link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
			<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
		{% endblock %}
		<link rel="icon" href="{{ asset('images/icon.ico') }}">
	</head>
	<body>
		<nav class="navbar navbar-expand-lg bg-info rounded-bottom-5 border-dark navfix" data-bs-theme="light">
			<div class="container-fluid  bg-success rounded-5 border border-3 border-dark">
				<a class="navbar-brand" href="{{ path('app_accueil') }}">
					<img class="border rounded-circle border-3 border-dark" src="{{ asset('images/icon.ico') }}" alt="Logo" height="60" width="60"/>
				</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor03" aria-controls="navbarColor03" aria-expanded="false" aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarColor03">
					<ul class="navbar-nav me-auto">
						<li class="nav-item">
							<a class="btn btn-info text-light ms-3 d-lg-inline-block d-block text-center my-1" href="{{ path('app_accueil') }}">Accueil</a>
						</li>
						<li class="nav-item">
							<a class="btn btn-info ms-3 d-lg-inline-block d-block text-center my-1" href="{{ path('app_commissions') }}">Commissions</a>
						</li>
						<li class="nav-item">
							<a class="btn btn-info ms-3 d-lg-inline-block d-block text-center my-1" href="{{ path('app_avis') }}">Avis</a>
						</li>
						{% if is_granted('IS_AUTHENTICATED_FULLY') %}
							<li class="nav-item">
								<a class="btn btn-warning text-light ms-3 d-block d-lg-none text-center my-1" href="{{ path('app_mes_favoris') }}">
									<i class="bi bi-heart-fill"></i> Mes Favoris
								</a>
								<a class="btn btn-light ms-3 d-none d-lg-inline-block" href="{{ path('app_mes_favoris') }}">Mes Favoris</a>
							</li>
							<li class="nav-item">
								<a class="btn btn-warning text-light ms-3 d-block d-lg-none text-center my-1" href="{{ path('app_commandes') }}">
									<i class="bi bi-bag-fill"></i> Mes Commandes
								</a>
								<a class="btn btn-light ms-3 d-none d-lg-inline-block" href="{{ path('app_commandes') }}">Mes Commandes</a>
							</li>
						{% endif %}
					</ul>

					<ul class="navbar-nav ms-auto">
						{% if is_granted('ROLE_ADMIN') %}
							<li class="nav-item ms-2">
								<a href="{{ path('app_admin') }}" class="btn btn-warning text-light ms-3 d-block d-lg-none text-center my-1">
									<i class="bi bi-speedometer2"></i> Dashboard Admin
								</a>
								<a href="{{ path('app_admin') }}" class="btn btn-warning d-none d-lg-inline-block">
									<i class="bi bi-speedometer2"></i> Dashboard
								</a>
							</li>
						{% endif %}

						{% if not is_granted('IS_AUTHENTICATED_FULLY') %}
							<li class="nav-item">
								<a class="btn btn-info text-light ms-3 d-block d-lg-none text-center my-1" href="{{ path('app_login') }}">
									<i class="bi bi-box-arrow-in-right"></i> Se connecter
								</a>
								<a class="btn btn-info ms-3 d-none d-lg-inline-block" href="{{ path('app_login') }}">
									<i class="bi bi-box-arrow-up-left"></i> Se connecter
								</a>
							</li>
							<li class="nav-item">
								<a class="btn btn-info text-light ms-3 d-block d-lg-none text-center my-1" href="{{ path('app_register') }}">
									<i class="bi bi-person-plus-fill"></i> S'inscrire
								</a>
								<a class="btn btn-info ms-3 d-none d-lg-inline-block" href="{{ path('app_register') }}">
									<i class="bi bi-person-plus-fill"></i> S'inscrire
								</a>
							</li>
						{% else %}
							<li class="nav-item ms-2">
								<a href="{{ path('app_panier') }}" class="btn btn-info text-light ms-3 d-block d-lg-none text-center my-1">
									<i class="bi bi-basket2-fill"></i> Mon Panier
									{% set total = 0 %}
									{% if app.user.panier %}
										{% for ligne in app.user.panier.ajouters %}
											{% set total = total + ligne.quantite %}
										{% endfor %}
									{% endif %}
									({{ total }})
								</a>
								<button type="button" class="btn btn-info position-relative d-none d-lg-inline-block">
									<a href="{{ path('app_panier') }}">
										<i class="bi bi-basket2-fill text-light"></i>
										<span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
											{% set total = 0 %}
											{% if app.user.panier %}
												{% for ligne in app.user.panier.ajouters %}
													{% set total = total + ligne.quantite %}
												{% endfor %}
											{% endif %}
											{{ total }}
											<span class="visually-hidden">articles dans le panier</span>
										</span>
									</a>
								</button>
							</li>
							<li class="nav-item ms-2">
								<a href="{{ path('app_profil') }}" class="btn btn-info text-light ms-3 d-block d-lg-none text-center my-1">
									<i class="bi bi-person-fill"></i> Mon Profil
								</a>
								<a href="{{ path('app_profil') }}" class="btn btn-info d-none d-lg-inline-block">
									<i class="bi bi-person-fill text-light"></i>
								</a>
							</li>
							<li class="nav-item">
								<a class="btn btn-warning text-light ms-3 d-block d-lg-none text-center my-1" href="{{ path('app_logout') }}">
									<i class="bi bi-x-circle-fill"></i> {{ app.user.email }} (Déconnexion)
								</a>
								<a class="nav-link bg-warning rounded-2 ms-2 text-dark border border-2 border-dark d-none d-lg-inline-block" href="{{ path('app_logout') }}">
									{{ app.user.email }} <i class="bi bi-x-circle-fill text-dark"></i>
								</a>
							</li>
						{% endif %}
					</ul>
				</div>
			</div>
		</nav>

		<div class="contain-footer">
		{% block body %}{% endblock %}
		</div>
		<footer class="mt-5 border-top border-3 border-dark bg-info">
			<div class="container py-4">
				<div class="row justify-content-between align-items-start gap-4">

					{# Logo + description #}
					<div class="col-auto">
						<p class="mocha text-light display-6 mb-1">PeachComs</p>
						<p class="garet text-light mb-0" style="font-size: 0.9rem;">
							Commissions artistiques furry
						</p>
					</div>

					{# Liens rapides #}
					<div class="col-auto">
						<p class="garet fw-bold text-light mb-2">Liens rapides</p>
						<ul class="list-unstyled garet mb-0">
							<li class="mb-1">
								<a href="{{ path('app_accueil') }}" class="text-light text-decoration-none">
									<i class="bi bi-house-fill me-1"></i> Accueil
								</a>
							</li>
							<li class="mb-1">
								<a href="{{ path('app_commissions') }}" class="text-light text-decoration-none">
									<i class="bi bi-palette-fill me-1"></i> Commissions
								</a>
							</li>
							{% if is_granted('IS_AUTHENTICATED_FULLY') %}
								<li class="mb-1">
									<a href="{{ path('app_mes_favoris') }}" class="text-light text-decoration-none">
										<i class="bi bi-heart-fill me-1"></i> Mes Favoris
									</a>
								</li>
								<li>
									<a href="{{ path('app_commandes') }}" class="text-light text-decoration-none">
										<i class="bi bi-bag-fill me-1"></i> Mes Commandes
									</a>
								</li>
							{% endif %}
						</ul>
					</div>

					{# Réseaux sociaux #}
					<div class="col-auto">
						<p class="garet fw-bold text-light mb-2">Me retrouver</p>
						<div class="d-flex gap-3">
							<a href="https://www.tiktok.com/@peachthefurry" target="_blank"
							   class="btn btn-success border border-2 border-dark rounded-circle"
							   style="width: 45px; height: 45px; padding: 0; line-height: 41px; text-align: center;">
								<i class="bi bi-tiktok text-info fs-5"></i>
							</a>
							<a href="https://discord.gg/toninvitation" target="_blank"
							   class="btn btn-success border border-2 border-dark rounded-circle"
							   style="width: 45px; height: 45px; padding: 0; line-height: 41px; text-align: center;">
								<i class="bi bi-discord text-info fs-5"></i>
							</a>
						</div>
					</div>

					{# Mentions légales #}
					<div class="col-auto">
						<p class="garet fw-bold text-light mb-2">Légal</p>
						<a href="{{ path('app_mentions_legales') }}" class="text-light garet text-decoration-none">
							<i class="bi bi-file-earmark-text-fill me-1"></i> Mentions légales
						</a>
					</div>

				</div>

				<hr class="border border-2 border-light mt-4 mb-3">
				<p class="text-center text-light garet mb-0" style="font-size: 0.85rem;">
					© {{ "now"|date("Y") }} PeachComs — Tous droits réservés
				</p>
			</div>
		</footer>

		{% block javascripts %}
			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
		{% endblock %}
	</body>
</html>