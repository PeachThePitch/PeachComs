<!doctype html>
<html lang="fr">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}PeachComs
			{% endblock %}
		</title>
		{% block stylesheets %}

			<link href="css/stylesheet.css" rel="stylesheet">
			<link href="css/bootstrap.min.css" rel="stylesheet">
			<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
		{% endblock %}
		<link rel="icon" href="images/icon.ico">
	</head>
	<body>
		<nav class="navbar navbar-expand-lg bg-info rounded-bottom-5 border-dark" data-bs-theme="light">
			<div class="container-fluid bg-success rounded-5 border border-2 border-dark">
				<a class="navbar-brand" href="" {{path('app_accueil')}}><img class="border rounded-circle border-2 border-dark" src="images/icon.ico" alt="Logo" height="60" width="60"/></a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bstarget="#navbarColor03" aria-controls="navbarColor03" aria-expanded="false" arialabel="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarColor03">
					<ul class="navbar-nav me-auto">
						<li class="nav-item">
							<a class="btn btn-info text-light ms-3" href="{{path('app_accueil')}}">Accueil
								<span class="visually-hidden">(current)</span>
							</a>
						</li>
						<li class="nav-item">
							<a class="btn btn-info ms-3" href="{{path('app_commissions')}}">Commissions</a>
						</li>
						{% if not is_granted('IS_AUTHENTICATED_FULLY') %}

							{% else %}
								<li class="nav-item">
									<a class="btn btn-light ms-3" href="{{path('app_favoris')}}">Mes Favoris</a>
								</li>
								<li class="nav-item">
									<a class="btn btn-light ms-3" href="{{path('app_commandes')}}">Mes Commandes</a>
								</li>
						{% endif %}
					</ul>


					<ul class="navbar-nav ms-auto ">
						{% if not is_granted('IS_AUTHENTICATED_FULLY') %}
							<li class="nav-item">
								<a class=" btn btn-info ms-3" href="{{path('app_login')}}">
									<i class="bi bi-box-arrow-up-left"></i>‎ ‎ Se connecter
								</a>
							</li>
							<li class="nav-item">
								<a class=" btn btn-info ms-3" href="{{path('app_register')}}">
									<i class="bi bi-person-plus-fill"></i>‎ ‎ S'inscrire
								</a>
							</li>

						{% else %}
							<li class="nav-item">
								<button type="button" class="btn btn-info position-relative">
									<i class="bi bi-basket2-fill text-light"></i>
									<span
										class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
										{#{{app.user.panier.ajouters | length}}#}
										{% set total = 0 %}
										{#{% for ajouter in app.user.panier.ajouters %}
																					{% set total = total + ajouter.quantite %}
																				{% endfor %}
																				{{total}}#}
										+99
										<span class="visually-hidden">unread messages</span>
									</span>
								</button>
							</li>
							<li class="nav-item ms-2">
								<a href="#" class="btn btn-info" role="button">
									<i class="bi bi-person-fill text-light"></i>
								</a>


							</li>
							<li class="nav-item">
								<a class="nav-link bg-warning  rounded-2 ms-2 text-dark border border-2 border-dark" href="{{path('app_logout')}}">
									{{app.user.email}}
									<i class="bi bi-x-circle-fill text-dark"></i>
								</a>
							</li>
						{% endif %}

					</ul>
				</div>
			</div>
		</nav>
		{% block body %}
		</body>
		<body>
			PeachComs

		</body>
	{% endblock %}
	{% block javascripts %}
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Q46cDfL" crossorigin="anonymous"></script>
	{% endblock %}
</html></body></body></html>
