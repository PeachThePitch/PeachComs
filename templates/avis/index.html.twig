{% extends 'base.html.twig' %}
{% block title %}{{ parent() }} - Avis clients{% endblock %}
{% block stylesheets %}
    <link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
    <div class="container mt-5 mb-5">

        <h1 class="mocha text-info display-1 text-center mb-2">Avis clients</h1>

        {# Note moyenne #}
        {% if avis is not empty %}
            <div class="text-center mb-4">
                <p class="mocha fs-1 text-info mb-0">{{ moyenne }}/5</p>
                <div class="d-flex justify-content-center gap-1 mb-2">
                    {% for i in 1..5 %}
                        <i class="bi {{ moyenne >= i ? 'bi-star-fill' : (moyenne >= i - 0.5 ? 'bi-star-half' : 'bi-star') }} text-warning fs-4"></i>
                    {% endfor %}
                </div>
                <p class="garet text-muted">{{ avis | length }} avis</p>
            </div>
        {% endif %}

        {# Bouton laisser un avis #}
        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
            <div class="text-center mb-5">
                <a href="{{ path('app_avis_laisser') }}" class="btn btn-info">
                    <span class="garet fw-bold text-light">
                        <i class="bi bi-star-fill"></i> Laisser un avis
                    </span>
                </a>
            </div>
        {% endif %}

        {# Liste des avis #}
        {% if avis is empty %}
            <p class="text-center garet fs-4 mt-5">Aucun avis pour l'instant 🌟</p>
        {% else %}
            <div class="row justify-content-center gap-4">
                {% for a in avis %}
                    <div class="col-auto">
                        <div class="border border-3 border-dark rounded-4 p-4 bg-white" style="width: 350px;">

                            {# Étoiles #}
                            <div class="d-flex gap-1 mb-2">
                                {% for i in 1..5 %}
                                    <i class="bi {{ a.note >= i ? 'bi-star-fill' : 'bi-star' }} text-warning fs-5"></i>
                                {% endfor %}
                            </div>

                            {# Image #}
                            {% if a.image %}
                                <img src="{{ asset('images/avis/' ~ a.image) }}"
                                     class="w-100 rounded-3 border border-2 border-dark mb-3"
                                     style="height: 200px; object-fit: cover;">
                            {% endif %}

                            {# Commentaire #}
                            {% if a.commentaire %}
                                <p class="garet mb-3" style="white-space: pre-line;">{{ a.commentaire }}</p>
                            {% endif %}

                            {# Auteur #}
                            <div class="d-flex justify-content-between align-items-center">
                                <p class="mocha text-info fs-5 mb-0">
                                    {{ a.user.pseudo ?? a.user.email }}
                                </p>
                                <small class="text-muted garet">
                                    {{ a.dateAvis | date('d/m/Y') }}
                                </small>
                            </div>

                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>
{% endblock %}