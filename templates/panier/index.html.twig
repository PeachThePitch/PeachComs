{% extends 'base.html.twig' %}
{% block title %}
    {{ parent() }} - Mon Panier
{% endblock %}
{% block stylesheets %}
    <link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
    <h1 class="ms-5 mocha text-info mt-4 pt-4 mb-4 display-1">
        Mon Panier
    </h1>

    {% if panier is null or panier.ajouters is empty %}
        <p class="text-center garet fs-4 mt-5">Ton panier est vide 🛒</p>
    {% else %}

        {% set total = 0 %}
        {% for ligne in panier.ajouters %}
            {% set total = total + (ligne.produit.prix * ligne.quantite) %}
        {% endfor %}
        {% set tva = total * 0.20 %}
        {% set totalTTC = total + tva %}

        <div class="container-fluid px-4">
            <div class="row gap-4 justify-content-center">

                {# ── Articles ── #}
                <div class="col-8">
                    {% for ligne in panier.ajouters %}
                        {% set produit = ligne.produit %}
                        <div class="d-flex flex-wrap align-items-center border border-3 border-dark rounded-4 mb-3 p-3 bg-white gap-3">

                            {# Image + Infos #}
                            <div class=" d-flex align-items-center gap-3 flex-grow-1 pro-panier ">
                                <img src="{{ asset('images/' ~ produit.image) }}"
                                     alt="{{ produit.designation }}"
                                     style="width: 250px; height: 100px; object-fit: cover;"
                                     class="rounded-3 border border-2 border-dark card-img">
                                <div class="pro-panier">
                                    <p class="mocha fw-bold fs-4 mb-1">{{ produit.designation }}</p>
                                    <p class="garet fw-bold text-info mb-0">{{ produit.prix | number_format(2, '.', '') }}€ / unité</p>
                                </div>
                            </div>

                            {# Quantité + Sous-total + Supprimer #}
                            <div class="d-flex align-items-center gap-3 ms-auto">
                                <div class="d-flex align-items-center gap-2">
                                    <a class="btn btn-sm btn-outline-dark" href="{{ path('app_panier_retirer', {'id': ligne.id}) }}">
                                        <i class="bi bi-dash"></i>
                                    </a>
                                    <span class="garet fw-bold fs-5">{{ ligne.quantite }}</span>
                                    <a class="btn btn-sm btn-outline-dark" href="{{ path('app_panier_ajouter', {'id': produit.id}) }}">
                                        <i class="bi bi-plus"></i>
                                    </a>
                                </div>
                                <div class="text-end" style="min-width: 90px;">
                                    <p class="garet fw-bold fs-5 mb-0">{{ (produit.prix * ligne.quantite) | number_format(2, '.', '') }}€</p>
                                </div>
                                <a class="btn btn-danger btn-sm" href="{{ path('app_panier_supprimer', {'id': ligne.id}) }}">
                                    <i class="bi bi-trash3-fill"></i>
                                </a>
                            </div>

                        </div>
                    {% endfor %}
                </div>

                {# ── Récapitulatif ── #}
                <div class="col-3">
                    <div class="border border-3 border-dark rounded-4 p-4 bg-white sticky-top" style="top: 100px;">

                        <p class="mocha fs-3 text-info text-center mb-4">Récapitulatif</p>

                        <div class="d-flex justify-content-between garet fw-bold mb-2">
                            <span>Sous-total HT</span>
                            <span>{{ total | number_format(2, '.', '') }}€</span>
                        </div>
                        <div class="d-flex justify-content-between garet fw-bold mb-2 text-muted">
                            <span>TVA (20%)</span>
                            <span>{{ tva | number_format(2, '.', '') }}€</span>
                        </div>

                        <hr class="border border-2 border-dark">

                        <div class="d-flex justify-content-between garet fw-bold fs-5 mb-4">
                            <span>Total TTC</span>
                            <span class="text-info">{{ totalTTC | number_format(2, '.', '') }}€</span>
                        </div>

                        <a href="{{ path('app_commande_passer') }}" class="btn btn-success w-100 mb-2">
                            <p class="garet fw-bold mb-0">
                                <i class="bi bi-credit-card-fill"></i> Commander
                            </p>
                        </a>

                        <p class="text-center text-muted garet mt-2" style="font-size: 0.8rem;">
                            <i class="bi bi-lock-fill"></i> Paiement 100% sécurisé
                        </p>

                    </div>
                </div>

            </div>
        </div>

    {% endif %}
{% endblock %}