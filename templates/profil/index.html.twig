{% extends 'base.html.twig' %}
{% block title %}{{ parent() }} - Mon Profil{% endblock %}
{% block stylesheets %}
    <link href="{{ asset('css/stylesheet.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
{% block body %}
    <div class="container mt-5 mb-5" style="max-width: 700px;">

        <h1 class="mocha text-info display-1 text-center mb-4">Mon Profil</h1>

        {% if erreur %}
            <div class="alert alert-danger garet border border-2 border-dark rounded-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ erreur }}
            </div>
        {% endif %}

        {% if succes %}
            <div class="alert alert-success garet border border-2 border-dark rounded-4">
                <i class="bi bi-check-circle-fill me-2"></i>{{ succes }}
            </div>
        {% endif %}

        {# ── Informations personnelles ── #}
        <div class="border border-3 border-dark rounded-4 p-4 bg-white mb-4">
            <h2 class="mocha text-info fs-2 mb-4">
                <i class="bi bi-person-fill"></i> Informations personnelles
            </h2>

            <form method="post">
                <input type="hidden" name="action" value="infos">

                <div class="row gap-3 mb-3">
                    <div class="col">
                        <label class="garet fw-bold mb-1">Prénom</label>
                        <input type="text" name="prenom"
                               class="form-control border border-2 border-dark rounded-3 garet"
                               value="{{ app.user.prenom ?? '' }}">
                    </div>
                    <div class="col">
                        <label class="garet fw-bold mb-1">Nom</label>
                        <input type="text" name="nom"
                               class="form-control border border-2 border-dark rounded-3 garet"
                               value="{{ app.user.nom ?? '' }}">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="garet fw-bold mb-1">Pseudo</label>
                    <input type="text" name="pseudo"
                           class="form-control border border-2 border-dark rounded-3 garet"
                           value="{{ app.user.pseudo ?? '' }}">
                </div>

                <div class="mb-4">
                    <label class="garet fw-bold mb-1">Email</label>
                    <input type="email" name="email"
                           class="form-control border border-2 border-dark rounded-3 garet"
                           value="{{ app.user.email }}" required>
                </div>

                <button type="submit" class="btn btn-info w-100">
                    <span class="garet fw-bold text-light">
                        <i class="bi bi-check-lg"></i> Enregistrer les modifications
                    </span>
                </button>
            </form>
        </div>

        {# ── Changer le mot de passe ── #}
        <div class="border border-3 border-dark rounded-4 p-4 bg-white mb-4">
            <h2 class="mocha text-info fs-2 mb-4">
                <i class="bi bi-lock-fill"></i> Changer le mot de passe
            </h2>

            <form method="post">
                <input type="hidden" name="action" value="password">

                <div class="mb-3">
                    <label class="garet fw-bold mb-1">Ancien mot de passe</label>
                    <input type="password" name="ancien_mdp"
                           class="form-control border border-2 border-dark rounded-3 garet" required>
                </div>

                <div class="mb-3">
                    <label class="garet fw-bold mb-1">Nouveau mot de passe</label>
                    <input type="password" name="nouveau_mdp"
                           class="form-control border border-2 border-dark rounded-3 garet" required>
                </div>

                <div class="mb-4">
                    <label class="garet fw-bold mb-1">Confirmer le nouveau mot de passe</label>
                    <input type="password" name="confirm_mdp"
                           class="form-control border border-2 border-dark rounded-3 garet" required>
                </div>

                <button type="submit" class="btn btn-info w-100">
                    <span class="garet fw-bold text-light">
                        <i class="bi bi-lock-fill"></i> Changer le mot de passe
                    </span>
                </button>
            </form>
        </div>

        {# ── Infos compte ── #}
        <div class="border border-3 border-dark rounded-4 p-4 bg-white">
            <h2 class="mocha text-info fs-2 mb-3">
                <i class="bi bi-info-circle-fill"></i> Mon compte
            </h2>
            <p class="garet mb-2">
                <strong>Rôle :</strong>
                {% if 'ROLE_ADMIN' in app.user.roles %}
                    <span class="badge bg-danger garet">Admin</span>
                {% else %}
                    <span class="badge bg-info garet">Client</span>
                {% endif %}
            </p>
            <p class="garet mb-2">
                <strong>Commandes :</strong> {{ app.user.commandes | length }}
            </p>
            <p class="garet mb-0">
                <strong>Favoris :</strong> {{ app.user.produits | length }}
            </p>
        </div>

    </div>
{% endblock %}